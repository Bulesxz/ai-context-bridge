#!/bin/bash
# ai-context-bridge: Git post-commit hook
# Auto-updates AI_CONTEXT.md after every commit
# Install: copy to .git/hooks/post-commit && chmod +x .git/hooks/post-commit

CONTEXT_FILE="AI_CONTEXT.md"
CUSTOM_START="<!-- CUSTOM:START -->"
CUSTOM_END="<!-- CUSTOM:END -->"

# Preserve user-written custom section
if [ -f "$CONTEXT_FILE" ]; then
  CUSTOM=$(awk "/$CUSTOM_START/,/$CUSTOM_END/" "$CONTEXT_FILE" 2>/dev/null)
fi

if [ -z "$CUSTOM" ]; then
  CUSTOM="$CUSTOM_START
## Next Step / 下一步
> Write what you plan to do next here.
$CUSTOM_END"
fi

{
echo "# AI Context Bridge"
echo ""
echo "> Auto-generated by [ai-context-bridge](https://github.com/Bulesxz/ai-context-bridge) · Updated: $(date '+%Y-%m-%d %H:%M:%S')"
echo ""
echo "$CUSTOM"
echo ""
echo "## Current Branch"
echo "`$(git rev-parse --abbrev-ref HEAD 2>/dev/null)`"
echo ""
echo "## Recent Commits"
echo '```'
git log --oneline -5 2>/dev/null || echo 'No commits yet'
echo '```'
echo ""
DIRTY=$(git status --short 2>/dev/null)
if [ -n "$DIRTY" ]; then
  echo "## Uncommitted Changes"
  echo '```'
  echo "$DIRTY"
  echo '```'
  echo ""
fi
echo "## Files Changed in Last Commit"
echo '```'
git diff --name-status HEAD~1 HEAD 2>/dev/null || echo 'Initial commit'
echo '```'
echo ""
echo "## TODOs in Code"
TODO=$(grep -rn 'TODO\|FIXME\|HACK' --include='*.ts' --include='*.tsx' --include='*.js' --include='*.jsx' --include='*.py' --include='*.go' --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=dist . 2>/dev/null | head -15)
if [ -n "$TODO" ]; then
  echo '```'
  echo "$TODO"
  echo '```'
else
  echo '_No TODOs found_'
fi
} > "$CONTEXT_FILE"

echo "✅ AI_CONTEXT.md updated (ai-context-bridge)"
